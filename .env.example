# Root reference only. Copy service-specific examples into local .env files.
# Do not commit real secrets.

# Backend subscriber and control API.
# Backend values can include secrets. Do not place these in frontend files.
MQTT_BROKER_URL=mqtts://your-hivemq-cloud-host:8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_TELEMETRY_TOPIC=omnisense/node/+/telemetry
MQTT_COMMAND_TOPIC_TEMPLATE=omnisense/node/{node_id}/command
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NODE_ENV=development

# Frontend dashboard. Only VITE_ values belong in apps/dashboard/.env.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_BASE_URL=http://localhost:3001

# Fake ESP32 publisher
MQTT_TELEMETRY_TOPIC_TEMPLATE=omnisense/node/{node_id}/telemetry
FAKE_PUBLISH_INTERVAL_MS=3000
